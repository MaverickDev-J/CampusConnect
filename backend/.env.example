# ═══════════════════════════════════════════════════════════════
# CampusConnect — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB ──────────────────────────────────────────────────
# Local (Docker):
MONGO_URI=mongodb://campusadmin:campuspass123@localhost:27017/campusconnect?authSource=admin
# Production (Atlas): uncomment and fill
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campusconnect?retryWrites=true&w=majority

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Gemini API Keys ──────────────────────────────────────────
# Single key (all pools share it):
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Separate key pools for rate-limit isolation.
# Comma-separated for multiple keys per pool.
# GEMINI_ROUTER_KEYS=key1,key2
# GEMINI_CHAT_KEYS=key1,key2
# GEMINI_INGESTION_KEYS=key1,key2

# ── Superadmin ───────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@campusconnect.local
SUPERADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ── CORS (Production) ───────────────────────────────────────
# Set this to your production frontend URL when deploying
# CORS_ORIGIN=https://campusconnect.yourdomain.com
